@model ZinarCompany.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Price" />
    <input type="hidden" asp-for="ImageUrl" />
    
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Category</label>
        <select asp-for="CategoryId"
                class="form-select"
                asp-items="ViewBag.Categories">
            <option value="">-- Select Category --</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="MaterialType" class="form-label"></label>
        <select asp-for="MaterialType" class="form-select">
            <option>Wood</option>
            <option>Aluminum</option>
        </select>
        <span asp-validation-for="MaterialType" class="text-danger"></span>
    </div>
   
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Change Product Image</label>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mb-2">
                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     style="max-height:150px;"
                     class="rounded border" />
            </div>
        }

        <input type="file"
               name="imageFile"
               class="form-control"
               accept="image/*" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
