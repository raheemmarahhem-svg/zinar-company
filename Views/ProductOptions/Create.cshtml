@model ZinarCompany.Models.ProductOption

<h2>Create Specification</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <!-- IMPORTANT -->
    <input type="hidden" asp-for="ProductId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="GroupName" class="form-label"></label>
        <input asp-for="GroupName" class="form-control" />
        <span asp-validation-for="GroupName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-secondary">Back</a>
</form>