@model ZinarCompany.Models.ProductOption

<h2>Delete Specification</h2>
<p>Are you sure you want to delete this?</p>

<ul>
    <li><b>Group:</b> @Model.GroupName</li>
    <li><b>Name:</b> @Model.Name</li>
</ul>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-secondary">Cancel</a>
</form>