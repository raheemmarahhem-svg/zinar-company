@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zinar Company</title>

    <!-- Bootstrap (CDN) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Your site css -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>

<body class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"
                    && ViewContext.RouteData.Values["action"]?.ToString()=="Index"
                    ? "home-page" : "")">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.svg" alt="Zinar Company Logo" style="height:32px;" class="me-2" />
                   
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Shop">Products</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                        }
                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-2">
                            @await Component.InvokeAsync("QuoteBadge")
                        </li>

                        <li class="nav-item">
                            @await Html.PartialAsync("_LoginPartial")
                        </li>
                    </ul>

                </div>
            </div>
        </nav>

        @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
        {
            <div id="zinarOfferBanner" class="zinar-offer" role="region" aria-label="Special offer">
                <div class="zinar-offer__inner">
                    <div class="zinar-offer__text">
                        <strong>Welcome back!</strong>
                        <span class="zinar-offer__sub">
                            Special offer for returning customers — ask us on WhatsApp
                        </span>
                    </div>
                </div>
            </div>
        }
    </header>

    @{
        var isHome = (ViewContext.RouteData.Values["controller"]?.ToString() == "Home"
        && ViewContext.RouteData.Values["action"]?.ToString() == "Index");
    }

    @if (isHome)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    }



    <!-- Bootstrap (CDN JS) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <footer class="premium-footer">
        <div class="footer-wrap">

            <div class="footer-col footer-brand">
                <h3>Zinar Company</h3>
                <p>Aluminum • PVC • Wood Systems</p>
            </div>

            <div class="footer-col">
                <h6>Contact</h6>

                <div class="footer-item">
                    <span class="footer-label">Phone</span>
                    <a class="footer-link" href="tel:+9647504506608">0750 450 6608</a>
                </div>

                <a href="https://wa.me/9647504506608"
                   target="_blank"
                   class="footer-whatsapp">
                    💬 WhatsApp
                </a>
            </div>

            <div class="footer-col">
                <h6>Address</h6>
                <p class="footer-muted">Duhok, Iraq</p>

                <a class="footer-link"
                   target="_blank"
                   href="https://www.google.com/maps?q=ZINAR+Aluminum+%26+PVC">
                    View on Google Maps →
                </a>
            </div>

        </div>

        <div class="footer-bottom">
            <span>© 2026 Zinar Company. All rights reserved.</span>
        </div>
    </footer>

    <script>
        window.ZinarOffer = (function () {
          const banner = () => document.getElementById("zinarOfferBanner");
          if (!banner()) return { hide: () => {} };

          const visitsKey = "zinar_visits";
          const dismissedKey = "zinar_offer_dismissed_until";

          const showAfterVisits = 5;
          const cooldownDays = 7;

          function nowMs(){ return Date.now(); }
          function daysMs(d){ return d * 24 * 60 * 60 * 1000; }

          function isDismissed() {
            const until = parseInt(localStorage.getItem(dismissedKey) || "0", 10);
            return until && until > nowMs();
          }

          function incrementVisits(){
            const current = parseInt(localStorage.getItem(visitsKey) || "0", 10);
            const next = current + 1;
            localStorage.setItem(visitsKey, String(next));
            return next;
          }

          function show(){
            banner()?.classList.remove("d-none");
          }

          function hide(){
            banner()?.classList.add("d-none");
            localStorage.setItem(dismissedKey, String(nowMs() + daysMs(cooldownDays)));
          }

          const visits = incrementVisits();
          if (visits >= showAfterVisits && !isDismissed()) {
            show();
          }

          return { hide };
        })();
    </script>

    <!-- AI Floating Button -->
    <button id="aiFab" class="ai-fab" type="button" aria-label="Open AI chat">AI</button>

    <!-- AI Chat Box -->
    <div id="aiChat" class="ai-chat d-none">
        <div class="ai-chat__header">
            <span>Zinar AI Support</span>
            <button id="aiClose" type="button" class="ai-chat__close" aria-label="Close">×</button>
        </div>

        <div id="aiMsgs" class="ai-chat__msgs"></div>

        <div class="ai-chat__input">
            <input id="aiText" type="text" placeholder="Ask about Zinar products..." />
            <button id="aiSend" type="button">Send</button>
        </div>
    </div>

    <!-- ✅ LOAD site.js ONCE and LAST -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        window.addEventListener("load", function () {
            document.body.classList.add("page-loaded");
        });
    </script>
</body>
</html>